---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

type Props = {
	title?: string;
	description?: string;
};

const { title = 'Qazwan — Systems for modern companies', description = 'Qazwan delivers offline-first POS, CMS, finance (AIS), warehouse (WMS), HR, clinic (CPMS), and property (REMS) software. Install on your hardware, own your data, train teams fast.' } =
	Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<!-- 1. PRIMARY METADATA & SEO -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="Qazwan, offline POS, retail software, inventory management, HR software, property management, clinic software, pharmacy POS, AIS accounting, WMS, IDBMS, CMS, REMS, CPMS, desktop business software" />
		<meta name="author" content="Qazwan" />
		<meta name="creator" content="Qazwan" />
		<meta name="publisher" content="Qazwan" />
		<meta name="copyright" content="© 2026 Qazwan" />
		<meta name="language" content="en" />
		<meta name="rating" content="general" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<meta name="generator" content={Astro.generator} />

		<!-- 2. ROBOTS & SEARCH ENGINE DIRECTIVES -->
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="bingbot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

		<!-- 3. BROWSER & APP THEMING -->
		<meta name="application-name" content="Qazwan" />
		<meta name="theme-color" content="#00bc7d" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#00bc7d" media="(prefers-color-scheme: dark)" />
		<meta name="color-scheme" content="light dark" />
		<meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />

		<!-- 4. APPLE / iOS METADATA -->
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="Qazwan" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#00bc7d" />

		<!-- 5. ANDROID / CHROME METADATA -->
		<meta name="mobile-web-app-capable" content="yes" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- 6. MICROSOFT / WINDOWS METADATA -->
		<meta name="msapplication-TileColor" content="#00bc7d" />
		<meta name="msapplication-config" content="/browserconfig.xml" />
		<meta name="msapplication-tooltip" content="Offline-first business software for retail, finance, HR, and operations" />
		<meta name="msapplication-tap-highlight" content="no" />

		<!-- 7. OPEN GRAPH (FACEBOOK/LINKEDIN/DISCORD) -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Qazwan" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content="https://devdocks.xyz/" />
		<meta property="og:image" content="https://devdocks.xyz/images/og.png" />
		<meta property="og:image:secure_url" content="https://devdocks.xyz/images/og.png" />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1448" />
		<meta property="og:image:height" content="1086" />
		<meta property="og:image:alt" content="Qazwan — offline-first business software for retail, finance, HR, and operations" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:locale:alternate" content="en_GB" />

		<!-- 8. TWITTER CARDS (X) -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@qazwan" />
		<meta name="twitter:creator" content="@qazwan" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://devdocks.xyz/images/og.png" />
		<meta name="twitter:image:alt" content="Qazwan — offline-first business software for retail, finance, HR, and operations" />

		<!-- 9. SCHEMA.ORG MICRODATA (HTML FALLBACK) -->
		<meta itemprop="name" content={title} />
		<meta itemprop="description" content={description} />
		<meta itemprop="image" content="https://devdocks.xyz/images/og.png" />
		<meta itemprop="url" content="https://devdocks.xyz/" />

		<!-- 10. DUBLIN CORE (ACADEMIC / ARCHIVAL) -->
		<meta name="DC.title" content={title} />
		<meta name="DC.creator" content="Qazwan" />
		<meta name="DC.subject" content="Offline-first business software for modern companies" />
		<meta name="DC.description" content={description} />
		<meta name="DC.publisher" content="Qazwan" />
		<meta name="DC.date" content="2026-06-06" />
		<meta name="DC.type" content="Text" />
		<meta name="DC.format" content="text/html" />
		<meta name="DC.identifier" content="https://devdocks.xyz/" />
		<meta name="DC.language" content="en" />
		<meta name="DC.coverage" content="World" />
		<meta name="DC.rights" content="© 2026 Qazwan" />

		<!-- 11. GEO TAGS (LOCATION METADATA) -->
		<meta name="geo.region" content="US" />
		<meta name="geo.placename" content="Your City" />
		<meta name="geo.position" content="0.0000;0.0000" />
		<meta name="ICBM" content="0.0000, 0.0000" />

		<!-- 12. PINTEREST & OTHER PLATFORMS -->
		<meta name="pinterest-rich-pin" content="true" />

		<!-- 13. CANONICAL, ALTERNATE, & ASSET LINKS -->
		<link rel="canonical" href="https://devdocks.xyz/" />
		<link rel="alternate" hreflang="en" href="https://devdocks.xyz/" />
		<link rel="alternate" hreflang="x-default" href="https://devdocks.xyz/" />
		<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
		<link rel="author" type="text/plain" href="/humans.txt" />
		<link rel="icon" type="image/png" sizes="32x32" href="/icon/32x32.png" />
		<link rel="icon" type="image/png" sizes="64x64" href="/icon/64x64.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="image_src" href="https://devdocks.xyz/images/og.png" />

		<!-- 14. RESOURCE HINTS (PERFORMANCE) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />

		<!-- 15. CSS / JS ASSETS -->
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet" />

		<!-- 16. JSON-LD STRUCTURED DATA (SCHEMA.ORG) -->
		<script id="qazwan-jsonld" type="application/ld+json" is:inline>
		{
		  "@context": "https://schema.org",
		  "@graph": [
			{
			  "@type": "Organization",
			  "@id": "https://devdocks.xyz/#organization",
			  "name": "Qazwan",
			  "url": "https://devdocks.xyz",
			  "logo": "https://devdocks.xyz/images/og.png",
			  "email": "hello@devdocks.xyz",
			  "description": "Offline-first business software for retail, finance, HR, and operations"
			},
			{
			  "@type": "WebSite",
			  "@id": "https://devdocks.xyz/#website",
			  "url": "https://devdocks.xyz",
			  "name": "Qazwan",
			  "description": "Offline-first business software for retail, finance, HR, and operations",
			  "publisher": { "@id": "https://devdocks.xyz/#organization" },
			  "inLanguage": "en",
			  "potentialAction": {
				"@type": "SearchAction",
				"target": "https://devdocks.xyz/docs/platform/overview?q={search_term_string}",
				"query-input": "required name=search_term_string"
			  }
			},
			{
			  "@type": "WebPage",
			  "@id": "https://devdocks.xyz/#webpage",
			  "url": "https://devdocks.xyz/",
			  "name": "Qazwan — Systems for modern companies",
			  "description": "Qazwan delivers database management systems for POS, CMS, finance (AIS), warehouse (WMS), HR, clinic (CPMS), and property (REMS) software.",
			  "isPartOf": { "@id": "https://devdocks.xyz/#website" },
			  "about": { "@id": "https://devdocks.xyz/#organization" },
			  "inLanguage": "en",
			  "primaryImageOfPage": {
				"@type": "ImageObject",
				"url": "https://devdocks.xyz/images/og.png",
				"width": 1448,
				"height": 1086
			  }
			}
		  ]
		}
		</script>
	</head>
	<body>
		<a class="skipLink" href="#main">Skip to content</a>
		<Nav />
		<main id="main">
			<slot />
		</main>
		<Footer />
		<script>
			import '../scripts/site-animations.ts';
		</script>
	</body>
</html>

<style is:global>
	/* Fonts (provided: SF Pro Display). */
	@font-face {
		font-family: 'SF Pro Display';
		src: url('/Fonts/sf-pro-display/SFPRODISPLAYREGULAR.OTF') format('opentype');
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}
	@font-face {
		font-family: 'SF Pro Display';
		src: url('/Fonts/sf-pro-display/SFPRODISPLAYMEDIUM.OTF') format('opentype');
		font-weight: 500;
		font-style: normal;
		font-display: swap;
	}
	@font-face {
		font-family: 'SF Pro Display';
		src: url('/Fonts/sf-pro-display/SFPRODISPLAYBOLD.OTF') format('opentype');
		font-weight: 700;
		font-style: normal;
		font-display: swap;
	}

	:root {
		/* Apple-inspired tokens (see .cursor/DESIGN.md) */
		--c-bg-light: #f5f5f7;
		--c-bg-dark: #000000;
		--c-text-light: #ffffff;
		--c-text-dark: #1d1d1f;
		--c-text-subtle: rgba(0, 0, 0, 0.8);
		--c-text-tertiary: rgba(0, 0, 0, 0.48);
		--c-accent: #0071e3;
		--c-link-light: #0066cc;
		--c-link-dark: #2997ff;

		--radius-5: 5px;
		--radius-8: 8px;
		--radius-11: 11px;
		--radius-12: 12px;
		--radius-pill: 980px;

		--shadow-card: rgba(0, 0, 0, 0.22) 3px 5px 30px 0px;

		--container: 980px;

		--font-display: 'SF Pro Display', 'SF Pro Icons', 'Helvetica Neue', Helvetica, Arial, sans-serif;
		--font-body: 'SF Pro Text', 'SF Pro Display', 'SF Pro Icons', 'Helvetica Neue', Helvetica, Arial, sans-serif;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		font-family: var(--font-body);
		background: var(--c-bg-light);
		color: var(--c-text-dark);
		text-rendering: geometricPrecision;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	body.navMobileOpen {
		overflow: hidden;
	}

	:where(a) {
		color: var(--c-link-light);
		text-decoration: none;
	}
	:where(a:hover) {
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	:focus-visible {
		outline: 2px solid var(--c-accent);
		outline-offset: 2px;
	}

	.navShell :focus-visible,
	.mobileBackdrop :focus-visible {
		outline-color: #fff;
	}

	.skipLink {
		position: absolute;
		left: 12px;
		top: 12px;
		padding: 10px 12px;
		border-radius: var(--radius-11);
		background: #ffffff;
		color: var(--c-text-dark);
		box-shadow: var(--shadow-card);
		transform: translateY(-160%);
		transition: transform 0.2s ease;
		z-index: 1000;
	}
	.skipLink:focus {
		transform: translateY(0);
	}

	/* Layout primitives */
	.container {
		max-width: var(--container);
		margin: 0 auto;
		padding: 0 16px;
	}

	.section {
		padding: 72px 0;
	}
	.section--dark {
		background: var(--c-bg-dark);
		color: var(--c-text-light);
	}
	.section--light {
		background: var(--c-bg-light);
		color: var(--c-text-dark);
	}

	.displayHero {
		font-family: var(--font-display);
		font-size: 56px;
		font-weight: 600;
		line-height: 1.07;
		letter-spacing: -0.28px;
		margin: 0;
	}
	.sectionHeading {
		font-family: var(--font-display);
		font-size: 40px;
		font-weight: 600;
		line-height: 1.1;
		margin: 0 0 12px;
	}
	.lede {
		font-size: 17px;
		line-height: 1.47;
		letter-spacing: -0.374px;
		margin: 12px 0 0;
		max-width: 65ch;
	}

	/* CTAs */
	.btnRow {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 22px;
	}
	.btnPrimary {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 8px 15px;
		border-radius: var(--radius-8);
		background: var(--c-accent);
		color: #ffffff;
		border: 1px solid transparent;
		font-size: 17px;
		line-height: 1;
	}
	.btnPrimary:hover {
		text-decoration: none;
		filter: brightness(1.05);
	}
	.btnPillLink {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px;
		border-radius: var(--radius-pill);
		border: 1px solid currentColor;
		font-size: 14px;
		line-height: 1.43;
		letter-spacing: -0.224px;
	}
	.btnPillLink:hover {
		text-decoration: none;
	}

	/* Cards */
	.grid3 {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 28px;
	}
	.card {
		border-radius: var(--radius-12);
		background: #ffffff;
		padding: 18px;
		box-shadow: var(--shadow-card);
	}
	.cardTitle {
		font-family: var(--font-display);
		font-size: 21px;
		font-weight: 700;
		line-height: 1.19;
		letter-spacing: 0.231px;
		margin: 10px 0 6px;
	}
	.cardBody {
		margin: 0;
		font-size: 14px;
		line-height: 1.29;
		letter-spacing: -0.224px;
		color: var(--c-text-subtle);
	}

	@media (max-width: 900px) {
		.displayHero {
			font-size: 40px;
			line-height: 1.1;
		}
		.grid3 {
			grid-template-columns: 1fr;
		}
		.section {
			padding: 56px 0;
		}
	}
</style>
