---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, Cpu, FolderTree, Layers, Lock, Monitor, Sparkles, Workflow } from '@lucide/astro';
import { GITHUB_RELEASES_URL, SITE_NAME } from '../config/site';
---

<Layout
	title={`About - ${SITE_NAME}`}
	description="DevDock is a Windows app that helps you run and manage a local web environment from one place. Start services, view logs, and edit configs without the manual setup."
>
	<section class="aboutHero section section--dark">
		<div class="container aboutHeroGrid">
			<div data-hero-intro>
				<p class="eyebrow" data-hero-line>About</p>
				<h1 class="displayHero" data-hero-line>Local development, simplified</h1>
				<p class="aboutLead" data-hero-line>
					<strong>{SITE_NAME}</strong> helps you run the services your web projects rely on, all from one clean Windows
					app. Start what you need, stop what you do not, and use logs and configuration tools to keep everything
					running smoothly.
				</p>
				<div class="btnRow" data-hero-line>
					<a class="btnPrimary" href={GITHUB_RELEASES_URL} target="_blank" rel="noreferrer">
						Download
					</a>
					<a class="aboutHeroLink" href="/how-to-use">
						How-to guide <ArrowRight size={16} />
					</a>
				</div>
			</div>
			<div class="aboutHeroVisual" data-hero-visual>
				<div class="aboutHeroCard">
					<Layers size={22} stroke-width={1.75} aria-hidden="true" />
					<div>
						<p class="aboutHeroCardTitle">C:\DevDock</p>
						<p class="aboutHeroCardSub">Service files, logs, and configs in one place.</p>
					</div>
				</div>
				<img
					class="aboutHeroImg"
					src="/images/2.png"
					alt="DevDock dashboard overview"
					width={1200}
					height={675}
					loading="eager"
				/>
			</div>
		</div>
	</section>

	<section class="section section--light">
		<div class="container">
			<div class="aboutWhatBlock" data-reveal>
				<h2 class="sectionHeading">What {SITE_NAME} does</h2>
				<p class="lede blockLede">
					DevDock gives you one place to manage a complete local environment. Instead of installing and managing separate
					tools by hand, you open one app and control the services you need.
				</p>
				<p class="bodyPara">
					It is designed for everyday work. Start your web server and database, open tools like an email inbox or a
					database UI, then stop everything when you are done.
				</p>
				<p class="bodyPara">
					DevDock also keeps logs and configuration options easy to access, so troubleshooting is straightforward.
				</p>
				<figure class="aboutSnippetFigure">
					<pre class="aboutSnippet" tabindex="0"><code>Where are my files?

DevDock keeps service files, logs, and configs in one place:
C:\DevDock</code></pre>
					<figcaption class="aboutSnippetCaption">One folder for your local environment</figcaption>
				</figure>
			</div>
		</div>
	</section>

	<section class="section section--dark">
		<div class="container">
			<h2 class="sectionHeading sectionHeadingOnDark" data-reveal>Designed for real workflows</h2>
			<div class="pillGrid" data-reveal-stagger>
				<div class="pillCard" data-reveal-item>
					<div class="pillIcon">
						<Workflow size={20} />
					</div>
					<h3 class="pillTitle">Service dashboard</h3>
					<p class="pillBody">
						Start, stop, and restart services. Open the right URL or folder quickly. Keep everything in a single place so
						your setup stays consistent.
					</p>
				</div>
				<div class="pillCard" data-reveal-item>
					<div class="pillIcon">
						<Monitor size={20} />
					</div>
					<h3 class="pillTitle">Fast and focused</h3>
					<p class="pillBody">
						A lightweight experience that keeps the tools you need close and reduces the friction of local development.
					</p>
				</div>
				<div class="pillCard" data-reveal-item>
					<div class="pillIcon">
						<FolderTree size={20} />
					</div>
					<h3 class="pillTitle">Predictable paths</h3>
					<p class="pillBody">
						Keep service files, logs, and configs organized in one root folder so you can always find what you need.
					</p>
				</div>
				<div class="pillCard" data-reveal-item>
					<div class="pillIcon">
						<Lock size={20} />
					</div>
					<h3 class="pillTitle">Configs and restarts</h3>
					<p class="pillBody">
						Edit configs and apply changes safely. If a service needs a restart to apply changes, DevDock helps you do
						that without guesswork.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section section--light">
		<div class="container">
			<div class="longRead" data-reveal>
				<h2 class="sectionHeading">Purpose and philosophy</h2>
				<p class="bodyPara">
					DevDock is built around a simple idea: local development should be easy to start and easy to maintain. The app
					stays out of your way and focuses on the actions you repeat every day.
				</p>
				<p class="bodyPara">
					If you prefer a predictable workspace, DevDock keeps service files, logs, and configuration in one root folder.
					That makes it easier to back up, troubleshoot, and reset specific services when needed.
				</p>
				<p class="bodyPara">
					The goal is confidence. You should be able to start services, confirm they are working, and solve problems
					quickly when something goes wrong.
				</p>
			</div>

			<div class="inlineFigure" data-reveal>
				<img src="/images/inside-computer.png" alt="DevDock configuration or detail view" width={1200} height={675} loading="lazy" />
			</div>
		</div>
	</section>

	<section class="section section--light mutedBand">
		<div class="container">
			<div class="reqGrid" data-reveal-stagger>
				<div class="reqCard" data-reveal-item>
					<div class="reqIcon">
						<Cpu size={20} />
					</div>
					<h3 class="reqTitle">System requirements</h3>
					<ul class="reqList">
						<li>Windows 10 or later</li>
						<li>Enough disk space for your projects and local services</li>
						<li>Administrator permissions may be required depending on service settings</li>
					</ul>
					<p class="reqNote">DevDock is currently focused on Windows.</p>
				</div>
				<div class="reqCard" data-reveal-item>
					<div class="reqIcon">
						<Sparkles size={20} />
					</div>
					<h3 class="reqTitle">Download</h3>
					<p class="reqBody">
						Get the latest installer and start using DevDock in minutes.
					</p>
					<a class="textLink" href={GITHUB_RELEASES_URL} target="_blank" rel="noreferrer">
						Open download page <ArrowRight size={16} />
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="section section--light">
		<div class="container" data-reveal>
			<div class="longRead">
				<h2 class="sectionHeading">Developer</h2>
				<p class="bodyPara">
					DevDock is built and maintained by an independent developer. If you need support, want to report a bug, or want
					to collaborate, use the contacts below.
				</p>
				<ul class="reqList">
					<li><strong>Name:</strong> Halwest Jamal</li>
					<li><strong>GitHub:</strong> <a href="https://github.com/halo000000">GitHub</a></li>
					<li><strong>Telegram:</strong> <a href="https://t.me/HAlwest0_0">Telegram</a></li>
				</ul>
			</div>
		</div>
	</section>

	<section class="section section--dark">
		<div class="container narrowDark" data-reveal>
			<h2 class="sectionHeading sectionHeadingOnDark">Privacy</h2>
			<p class="lede ledeDark">
				We believe privacy documentation should be concrete and easy to understand. A full policy is in progress. For now
				you can read the draft page that reserves space for future counsel approved text.
			</p>
			<a class="aboutPrivacyCta" href="/privacy">
				Read the privacy policy (draft) <ArrowRight size={16} />
			</a>
		</div>
	</section>
</Layout>

<style>
	.aboutHero {
		padding-top: 56px;
		padding-bottom: 80px;
	}

	.aboutHeroGrid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 40px;
		align-items: center;
	}

	.eyebrow {
		margin: 0 0 12px;
		font-size: 13px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
		font-weight: 500;
	}

	.aboutLead {
		margin: 16px 0 0;
		font-size: 19px;
		line-height: 1.45;
		letter-spacing: -0.25px;
		color: rgba(255, 255, 255, 0.82);
		max-width: 52ch;
	}

	.aboutHeroLink {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--c-link-dark);
		font-size: 17px;
		text-decoration: none;
	}
	.aboutHeroLink:hover {
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	.aboutHeroVisual {
		position: relative;
	}

	.aboutHeroImg {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 14px;
		box-shadow:
			0 0 0 1px rgba(255, 255, 255, 0.06),
			0 40px 100px rgba(0, 0, 0, 0.5);
	}

	.aboutHeroCard {
		position: absolute;
		bottom: -10px;
		left: -10px;
		display: flex;
		gap: 14px;
		align-items: flex-start;
		max-width: 260px;
		padding: 16px 18px;
		border-radius: var(--radius-12);
		background: rgba(32, 32, 34, 0.95);
		backdrop-filter: blur(14px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: #fff;
	}
	.aboutHeroCard :global(svg) {
		flex-shrink: 0;
		opacity: 0.9;
	}
	.aboutHeroCardTitle {
		margin: 0;
		font-size: 14px;
		font-weight: 600;
	}
	.aboutHeroCardSub {
		margin: 4px 0 0;
		font-size: 12px;
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.55);
	}

	.aboutWhatBlock {
		max-width: 72ch;
	}
	.blockLede {
		max-width: none;
	}
	.bodyPara {
		margin: 16px 0 0;
		font-size: 17px;
		line-height: 1.55;
		letter-spacing: -0.3px;
		color: var(--c-text-subtle);
		max-width: 68ch;
	}

	.aboutSnippetFigure {
		margin: 22px 0 0;
		padding: 0;
	}
	.aboutSnippet {
		margin: 0;
		padding: 14px 16px;
		border-radius: var(--radius-8);
		background: #1c1c1e;
		border: 1px solid rgba(255, 255, 255, 0.08);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
		font-size: 12px;
		line-height: 1.5;
		color: rgba(235, 235, 245, 0.85);
		overflow-x: auto;
		tab-size: 2;
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
	}
	.aboutSnippet code {
		font: inherit;
		white-space: pre-wrap;
		word-break: break-word;
	}
	.aboutSnippetCaption {
		margin: 10px 0 0;
		font-size: 13px;
		color: rgba(0, 0, 0, 0.45);
	}

	.sectionHeadingOnDark {
		color: #fff;
	}
	.ledeDark {
		color: rgba(255, 255, 255, 0.78);
	}

	.pillGrid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 16px;
		margin-top: 28px;
	}
	.pillCard {
		padding: 22px;
		border-radius: var(--radius-12);
		background: #141416;
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	.pillIcon {
		width: 40px;
		height: 40px;
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.08);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
		margin-bottom: 12px;
	}
	.pillTitle {
		margin: 0 0 8px;
		font-family: var(--font-display);
		font-size: 19px;
		font-weight: 600;
		color: #fff;
	}
	.pillBody {
		margin: 0;
		font-size: 15px;
		line-height: 1.45;
		color: rgba(255, 255, 255, 0.65);
	}

	.longRead {
		max-width: 720px;
	}

	.inlineFigure {
		margin-top: 40px;
		border-radius: var(--radius-12);
		overflow: hidden;
		box-shadow: var(--shadow-card);
	}
	.inlineFigure img {
		display: block;
		width: 100%;
		height: auto;
	}

	.mutedBand {
		background: #ebebed;
	}

	.reqGrid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 18px;
	}
	.reqCard {
		background: #fff;
		border-radius: var(--radius-12);
		padding: 24px;
		box-shadow: var(--shadow-card);
	}
	.reqIcon {
		width: 40px;
		height: 40px;
		border-radius: 10px;
		background: var(--c-bg-light);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 12px;
	}
	.reqTitle {
		margin: 0 0 10px;
		font-family: var(--font-display);
		font-size: 21px;
		font-weight: 600;
	}
	.reqList {
		margin: 0;
		padding-left: 1.1em;
		font-size: 15px;
		line-height: 1.5;
		color: var(--c-text-subtle);
	}
	.reqNote {
		margin: 14px 0 0;
		font-size: 13px;
		color: rgba(0, 0, 0, 0.45);
	}
	.reqBody {
		margin: 0 0 14px;
		font-size: 15px;
		line-height: 1.45;
		color: var(--c-text-subtle);
	}
	.textLink {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 15px;
		font-weight: 500;
		color: var(--c-link-light);
		text-decoration: none;
	}
	.textLink:hover {
		text-decoration: underline;
	}

	.narrowDark {
		max-width: 720px;
		margin: 0 auto;
	}
	.aboutPrivacyCta {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin-top: 18px;
		font-size: 17px;
		color: var(--c-link-dark);
		text-decoration: none;
	}
	.aboutPrivacyCta:hover {
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	@media (max-width: 900px) {
		.aboutHeroGrid {
			grid-template-columns: 1fr;
		}
		.aboutHeroVisual {
			order: -1;
		}
		.aboutHeroCard {
			position: relative;
			bottom: auto;
			left: auto;
			max-width: none;
			margin-top: 12px;
		}
		.pillGrid {
			grid-template-columns: 1fr;
		}
		.reqGrid {
			grid-template-columns: 1fr;
		}
	}
</style>
