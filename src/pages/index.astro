---
import Layout from '../layouts/Layout.astro';
import {
	ArrowRight,
	CheckCircle2,
	ChevronDown,
	ChevronRight,
	Database,
	Download,
	Globe,
	HelpCircle,
	Layers,
	LayoutGrid,
	Mail,
	Server,
	Shield,
	Table,
	Terminal,
	Zap,
} from '@lucide/astro';
import { GITHUB_RELEASES_URL, SITE_NAME } from '../config/site';

const screenshots = [
	{ src: '/images/Frame 62.png', alt: 'DevDock application - dashboard and services' },
	{ src: '/images/2.png', alt: 'DevDock application - workspace' },
	{ src: '/images/3.png', alt: 'DevDock application - detail view' },
];

/** Flat grid under “Why you should use DevTools”: image + title + subtext + link (no card chrome). */
const featureColumns = [
	{
		img: { src: '/images/Frame 62.png', alt: 'DevDock feature preview - services dashboard' },
		title: 'Orchestration without the scavenger hunt',
		body: 'Start and stop the services you need from one place. No more hunting for separate installers, toggles, and shortcuts every time you begin work.',
		href: '/about',
		linkLabel: 'Learn more',
	},
	{
		img: { src: '/images/Frame 59.png', alt: 'DevDock feature preview - logs and diagnostics' },
		title: 'Logs you can actually read',
		body: 'When something fails, you should not guess. DevDock puts service logs in one place so you can quickly see what happened and what to fix.',
		href: '/about',
		linkLabel: 'Learn more',
	},
	{
		img: { src: '/images/Frame 63.png', alt: 'DevDock feature preview - tools and extras' },
		title: 'Extras in one window',
		body: 'Useful tools sit next to your services so you stay focused. Do common tasks without switching between a dozen separate apps.',
		href: '/about',
		linkLabel: 'Learn more',
	},
];

const faq = [
	{
		q: 'What is DevDock?',
		a: 'DevDock is a Windows desktop app that helps you run and manage a full local web environment from one place.',
	},
	{
		q: 'Is DevDock only for Windows?',
		a: 'Yes. DevDock is designed for Windows and focuses on making local services feel simple and reliable.',
	},
	{
		q: 'What is C:\\DevDock?',
		a: 'It is the main folder DevDock uses to keep local service files organized. If you ever need to find configs, logs, or your web root, you will find them there.',
	},
	{
		q: 'Where do I put my website files?',
		a: 'Put your project files in the web root folder inside C:\\DevDock. Then start the web service in DevDock and open localhost in your browser.',
	},
	{
		q: 'Which ports does DevDock use by default?',
		a: 'Defaults depend on your configuration. If something will not start, DevDock shows the reason, and the logs will point to common issues like a port conflict.',
	},
	{
		q: 'How do I download DevDock?',
		a: 'Use the Download button to open the latest release and run the Windows installer.',
	},
	{
		q: 'What is the HTTP Client tab for?',
		a: 'It helps you test your local API endpoints quickly without needing extra tools.',
	},
	{
		q: 'How do logs work?',
		a: 'DevDock shows logs per service so you can filter and focus. You can also open log files on disk when you need to share or review them.',
	},
	{
		q: 'Can I edit configs inside the app?',
		a: 'Yes. For most services you can open the config from DevDock, make changes, save, and restart the service so changes apply.',
	},
	{
		q: 'A service will not start. What should I do?',
		a: 'Open the service logs and look for the first error. The most common causes are a port conflict, missing permissions, or a misconfigured option. Fix the issue, then restart the service.',
	},
];

/** Bundled / orchestrated services (from project documentation). */
const integrations = [
	{ name: 'NGINX', Icon: Globe },
	{ name: 'PHP', Icon: Terminal },
	{ name: 'MySQL', Icon: Database },
	{ name: 'Mailpit', Icon: Mail },
	{ name: 'phpMyAdmin', Icon: Table },
	{ name: 'FTP', Icon: Server },
	{ name: 'SQL Web', Icon: Layers },
] as const;
---

<Layout
	title={`${SITE_NAME} - Local web services, simplified`}
	description="DevDock helps you run a full local web environment on Windows from one simple desktop app. Start services, view logs, and manage configs without the manual setup."
>
	<!-- Hero -->
	<section class="hero section section--dark">
		<div class="container container--wide heroGrid heroGrid--hero">
			<div class="heroCopy" data-hero-intro>
				<p class="eyebrow" data-hero-line>Local web services for Windows</p>
				<h1 class="displayHero heroHeadline" data-hero-line>{SITE_NAME}</h1>
				<p class="heroSub" data-hero-line>
					Run your local web environment from one clean dashboard. Start the services you need, keep configs organized,
					and use logs to fix issues fast.
				</p>
				<div class="heroActions" data-hero-line>
					<a class="btnPrimary heroPrimary" href={GITHUB_RELEASES_URL} target="_blank" rel="noreferrer">
						<Download size={18} stroke-width={2} />
						Download
					</a>
					<a class="heroLink" href="/how-to-use">
						How to use DevDock
						<ChevronRight size={18} stroke-width={2} aria-hidden="true" />
					</a>
				</div>
				<ul class="heroMeta" data-hero-line>
					<li><CheckCircle2 size={16} stroke-width={2} aria-hidden="true" /> Start what you need in seconds</li>
					<li><CheckCircle2 size={16} stroke-width={2} aria-hidden="true" /> Logs in one place</li>
					<li><CheckCircle2 size={16} stroke-width={2} aria-hidden="true" /> Configs you can find and edit</li>
				</ul>
			</div>

			<div class="heroVisual" data-hero-visual>
				<div class="heroFrame">
					<img
						class="heroFrameImg"
						src="/images/Hero-image.png"
						alt="DevDock application preview showing services and tools"
						width={1200}
						height={675}
						fetchpriority="high"
					/>
				
			</div>
		</div>
	</section>

	<!-- Bento (Apple-style large tiles + imagery) -->
	<section class="section section--light bentoSection">
		<div class="container container--wide">
			<div class="sectionIntro sectionIntro--center" data-reveal>
				<h2 class="sectionHeading">Your local stack, one surface</h2>
				<p class="lede sectionLede sectionLede--center">
					DevDock gives you one place to manage local services. Start and stop what you need, open the right tools fast,
					and keep your work moving without repetitive setup.
				</p>
			</div>

			<div class="bentoApple" data-reveal-stagger>
				<article class="bentoHero" data-reveal-item>
					<div class="bentoHeroCopy">
						<p class="bentoEyebrow">Services</p>
						<h3 class="bentoHeroTitle">Everything you need, in one dashboard</h3>
						<p class="bentoHeroText">
							Start, stop, and restart services. Open the right URL or folder in one click. When something breaks, open
							the logs and fix it without guessing.
						</p>
					</div>
					<div class="bentoHeroMedia">
						<img src="/images/MacBook-Pro-16.png" alt="DevDock services dashboard" loading="lazy" width={1600} height={900} />
					</div>
				</article>

				<article class="bentoSide bentoSideA" data-reveal-item>
					<div class="bentoIconXL">
						<Zap size={36} stroke-width={1.5} />
					</div>
					<h3 class="bentoSideTitle">Logs &amp; HTTP tooling</h3>
					<p class="bentoSideText">
						View logs per service and spot errors quickly. Use built in tools to test endpoints and verify behavior while
						you develop.
					</p>
				</article>

				<article class="bentoSide bentoSideB" data-reveal-item>
					<div class="bentoIconXL">
						<Shield size={36} stroke-width={1.5} />
					</div>
					<h3 class="bentoSideTitle">Project helpers</h3>
					<p class="bentoSideText">
						Create a quick local database when you need one. Keep project helpers nearby so common tasks stay simple.
					</p>
				</article>

				<article class="bentoBand" data-reveal-item>
					<div class="bentoBandStat">
						<span class="bentoBandNum">7</span>
						<span class="bentoBandLabel">core services (typical)</span>
					</div>
					<p class="bentoBandCopy">
						A complete set of services for local development, plus optional helpers for local domains and HTTPS when you
						need them.
					</p>
				</article>
			</div>
		</div>
	</section>

	<!-- Integrations marquee -->
	<section class="section section--dark marqueeSection" aria-label="Supported integrations">
		<div class="container container--wide marqueeIntro">
			<p class="marqueeEyebrow" data-reveal>Services</p>
			<h2 class="sectionHeading sectionHeadingOnDark marqueeTitle" data-reveal>
				What you can run
			</h2>
			<p class="lede ledeDark marqueeSub" data-reveal>
				Start the services you need for your project and keep them all in one place.
			</p>
		</div>
		<div class="marqueeMask" data-reveal>
			<div class="marqueeTrack">
				<div class="marqueeChunk">
					{
						integrations.map(({ name, Icon }) => (
							<div class="marqueeItem">
								<span class="marqueeIcon" aria-hidden="true">
									<Icon size={32} stroke-width={1.5} />
								</span>
								<span class="marqueeName">{name}</span>
							</div>
						))
					}
				</div>
				<div class="marqueeChunk" aria-hidden="true">
					{
						integrations.map(({ name, Icon }) => (
							<div class="marqueeItem">
								<span class="marqueeIcon" aria-hidden="true">
									<Icon size={32} stroke-width={1.5} />
								</span>
								<span class="marqueeName">{name}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- Gallery -->
	<section class="section section--dark gallerySection">
		<div class="container container--wide">
			<div class="sectionIntro sectionIntro--center" data-reveal>
				<h2 class="sectionHeading sectionHeadingOnDark">See the shell</h2>
				<p class="lede ledeDark sectionLede sectionLede--center">
					A quick look at the dashboard, tools, and service views.
				</p>
			</div>
			<div class="shotsApple" data-reveal-stagger>
				<figure class="shot shotHero" data-reveal-item>
					<img src="/images/Frame 62.png" alt={screenshots[0].alt} loading="lazy" width={1600} height={900} />
				</figure>
				<figure class="shot shotSide" data-reveal-item>
					<img src="/images/Frame 59.png" alt={screenshots[1].alt} loading="lazy" width={1200} height={675} />
				</figure>
				<figure class="shot shotSide" data-reveal-item>
					<img src="/images/Frame 63.png" alt={screenshots[2].alt} loading="lazy" width={1200} height={675} />
				</figure>
			</div>
		</div>
	</section>

	<!-- Features: flat grid with image, title, text, link -->
	<section class="section section--light featuresSection">
		<div class="container container--wide featuresWrap">
			<div class="sectionIntro sectionIntro--center featuresHeroIntro" data-reveal>
				<h2 class="featuresDisplayTitle">Why you should use DevTools</h2>
				<p class="lede featuresHeroLede sectionLede sectionLede--center">
					Skip repetitive setup. DevDock helps you get your local environment running fast, then stay productive with the
					right tools close by.
				</p>
			</div>
			<div class="featuresGrid featuresGridFlat" data-reveal-stagger>
				{featureColumns.map((col) => (
					<article class="featureCell" data-reveal-item>
						<div class="featureMedia">
							<img
								src={col.img.src}
								alt={col.img.alt}
								width={1200}
								height={800}
								loading="lazy"
								decoding="async"
							/>
						</div>
						<h3 class="featureCellTitle">{col.title}</h3>
						<p class="featureCellDesc">{col.body}</p>
						{/* <a class="featureCellLink" href={col.href}>
							{col.linkLabel} <ArrowRight size={16} stroke-width={2} />
						</a> */}
					</article>
				))}
			</div>
			<div class="midCta" data-reveal>
				<a class="textCta" href="/about">
					Read the full story <ArrowRight size={16} />
				</a>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="section section--dark faqSection">
		<div class="container container--wide">
			<div class="faqHeader" data-reveal>
				<div class="faqIconLabel">
					<HelpCircle size={22} stroke-width={1.75} aria-hidden="true" />
					<span>FAQ</span>
				</div>
				<h2 class="sectionHeading sectionHeadingOnDark">Questions, answered</h2>
				<p class="lede ledeDark faqDeckSub">
					Simple answers to common questions.
				</p>
			</div>
			<div class="faqList" data-reveal-stagger>
				{faq.map((item) => (
					<details class="faqItem" data-reveal-item name="faq">
						<summary class="faqSummary">
							<span class="faqQ">{item.q}</span>
							<span class="faqChevron" aria-hidden="true">
								<ChevronDown size={24} stroke-width={2} />
							</span>
						</summary>
						<div class="faqAnswerWrap">
							<p class="faqAnswer">{item.a}</p>
						</div>
					</details>
				))}
			</div>
		</div>
	</section>

	<!-- Closing CTA -->
	<section class="section section--light ctaBand">
		<div class="container ctaRow" data-reveal>
			<div>
				<h2 class="sectionHeading ctaTitle">Ready to run {SITE_NAME}?</h2>
				<p class="lede ctaLede">
					Download the latest release, install on Windows, and follow the guide to start your local environment.
				</p>
			</div>
			<div class="ctaActions">
				<a class="btnPrimary" href={GITHUB_RELEASES_URL} target="_blank" rel="noreferrer">
					<Download size={18} />
					Download
				</a>
				<a class="textCta" href="/how-to-use">
					How to use <ArrowRight size={16} />
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding-top: 56px;
		padding-bottom: 88px;
		min-height: min(92vh, 900px);
		display: flex;
		align-items: center;
	}

	.heroGrid {
		display: grid;
		grid-template-columns: 1fr 1.05fr;
		gap: 48px;
		align-items: center;
	}
	@media (min-width: 1100px) {
		.heroGrid--hero {
			grid-template-columns: minmax(420px, 0.9fr) minmax(0, 1.6fr);
			gap: 56px;
		}
	}

	.heroCopy {
		max-width: 520px;
	}

	.eyebrow {
		margin: 0 0 12px;
		font-size: 13px;
		line-height: 1.3;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.55);
		font-weight: 500;
	}

	.heroHeadline {
		color: #fff;
	}

	.heroSub {
		margin: 16px 0 0;
		font-size: 21px;
		line-height: 1.35;
		letter-spacing: -0.3px;
		color: rgba(255, 255, 255, 0.82);
		font-weight: 400;
		max-width: 42ch;
	}

	.heroActions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 14px 22px;
		margin-top: 28px;
	}

	.heroPrimary {
		padding: 11px 20px;
		font-size: 17px;
	}

	.heroLink {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		color: var(--c-link-dark);
		font-size: 17px;
		font-weight: 400;
		text-decoration: none;
		background: none;
		border: none;
		padding: 8px 0;
	}
	.heroLink:hover {
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	.heroMeta {
		list-style: none;
		margin: 32px 0 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 12px 20px;
		font-size: 13px;
		letter-spacing: -0.12px;
		color: rgba(255, 255, 255, 0.55);
	}
	.heroMeta li {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	.heroVisual {
		position: relative;
		justify-self: end;
		width: 100%;
	}

	.heroFrame {
		border-radius: 14px;
		overflow: hidden;
		background: #0d0d0d;
		width: min(980px, 100%);
		margin-left: auto;
		box-shadow:
			0 0 0 1px rgba(255, 255, 255, 0.06),
			0 40px 100px rgba(0, 0, 0, 0.55);
	}
	.heroFrameChrome {
		height: 36px;
		background: linear-gradient(180deg, #2a2a2c 0%, #1c1c1e 100%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.heroFrameImg {
		display: block;
		width: 130%;
		height: auto;
		vertical-align: middle;
	}

	.heroFloatCard {
		position: absolute;
		bottom: -12px;
		left: -12px;
		max-width: 240px;
		display: flex;
		gap: 14px;
		align-items: flex-start;
		padding: 16px 18px;
		border-radius: var(--radius-12);
		background: rgba(39, 39, 41, 0.92);
		backdrop-filter: blur(16px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: #fff;
		box-shadow: var(--shadow-card);
	}
	.heroFloatCard :global(svg) {
		flex-shrink: 0;
		opacity: 0.9;
	}
	.heroFloatTitle {
		margin: 0;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: -0.14px;
	}
	.heroFloatSub {
		margin: 4px 0 0;
		font-size: 12px;
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.55);
	}

	.sectionIntro {
		margin-bottom: 36px;
	}
	.sectionIntro--center {
		text-align: center;
		max-width: 820px;
		margin-left: auto;
		margin-right: auto;
	}
	.sectionLede {
		max-width: 62ch;
		margin-top: 14px;
	}
	.sectionLede--center {
		margin-left: auto;
		margin-right: auto;
	}

	.container--wide {
		max-width: 1120px;
	}

	.sectionHeadingOnDark {
		color: #fff;
	}
	.ledeDark {
		color: rgba(255, 255, 255, 0.78);
	}

	.bentoSection {
		padding-top: 96px;
		padding-bottom: 96px;
	}

	/* Apple-style bento */
	.bentoApple {
		display: grid;
		grid-template-columns: 1.25fr 1fr;
		grid-template-rows: minmax(280px, auto) minmax(240px, auto) auto;
		gap: 16px;
		margin-top: 8px;
	}

	.bentoHero {
		grid-column: 1;
		grid-row: 1 / 3;
		display: flex;
		flex-direction: column;
		background: #fff;
		border-radius: 18px;
		overflow: hidden;
		box-shadow: var(--shadow-card);
		min-height: 520px;
	}

	.bentoHeroCopy {
		padding: 36px 40px 28px;
	}
	.bentoEyebrow {
		margin: 0 0 10px;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgba(0, 0, 0, 0.45);
	}
	.bentoHeroTitle {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(28px, 3.2vw, 40px);
		font-weight: 600;
		line-height: 1.08;
		letter-spacing: -0.4px;
		color: var(--c-text-dark);
	}
	.bentoHeroText {
		margin: 14px 0 0;
		font-size: 18px;
		line-height: 1.45;
		letter-spacing: -0.25px;
		color: var(--c-text-subtle);
		max-width: 42ch;
	}

	.bentoHeroMedia {
		flex: 1;
		min-height: 320px;
		background: #0a0a0a;
		display: flex;
		align-items: flex-end;
	}
	.bentoHeroMedia img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
		display: block;
	}

	.bentoSide {
		background: #fff;
		border-radius: 18px;
		padding: 36px 32px;
		box-shadow: var(--shadow-card);
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: 220px;
	}
	.bentoSideA {
		grid-column: 2;
		grid-row: 1;
	}
	.bentoSideB {
		grid-column: 2;
		grid-row: 2;
	}
	.bentoIconXL {
		width: 64px;
		height: 64px;
		border-radius: 16px;
		background: var(--c-bg-light);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--c-text-dark);
		margin-bottom: 18px;
	}
	.bentoSideTitle {
		margin: 0 0 10px;
		font-family: var(--font-display);
		font-size: 22px;
		font-weight: 600;
		letter-spacing: -0.2px;
		line-height: 1.15;
		color: var(--c-text-dark);
	}
	.bentoSideText {
		margin: 0;
		font-size: 16px;
		line-height: 1.45;
		color: var(--c-text-subtle);
		max-width: 36ch;
	}

	.bentoBand {
		grid-column: 1 / -1;
		grid-row: 3;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 28px 48px;
		padding: 36px 40px;
		border-radius: 18px;
		background: linear-gradient(180deg, #fafafc 0%, #f5f5f7 100%);
		box-shadow: var(--shadow-card);
	}
	.bentoBandStat {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 120px;
	}
	.bentoBandNum {
		font-family: var(--font-display);
		font-size: clamp(48px, 6vw, 72px);
		font-weight: 600;
		line-height: 1;
		letter-spacing: -2px;
		color: var(--c-text-dark);
	}
	.bentoBandLabel {
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(0, 0, 0, 0.45);
	}
	.bentoBandCopy {
		margin: 0;
		flex: 1;
		font-size: 19px;
		line-height: 1.4;
		letter-spacing: -0.3px;
		color: var(--c-text-subtle);
		max-width: 52ch;
	}

	/* Marquee */
	.marqueeSection {
		padding-top: 72px;
		padding-bottom: 56px;
	}
	.marqueeIntro {
		text-align: center;
		margin-bottom: 8px;
	}
